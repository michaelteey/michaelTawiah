---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Michael Tawiah">
  <main>
    <section class="hero">
      <h1>Michael Tawiah</h1>
      <p>Website coming soon.</p>
    </section>
  </main>
</Layout>

<style>
  main {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 2rem;
  }
  .hero {
    text-align: center;
    max-width: 40rem;
  }
  h1 {
    font-size: clamp(2.5rem, 8vw, 5rem);
    margin: 0 0 0.5rem;
    letter-spacing: -0.02em;
  }
  p {
    font-size: 1.125rem;
    color: var(--muted);
    margin: 0;
  }
</style>
