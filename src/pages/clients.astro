---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { clients } from '../data/clients';

const grouped = clients.reduce<Record<string, typeof clients>>((acc, c) => {
  const key = c.sector ?? 'other';
  (acc[key] ??= []).push(c);
  return acc;
}, {});
const sectors = Object.keys(grouped).sort();
---

<Layout
  title="clients — michael tawiah"
  description="brands and businesses i've worked with across 10+ years of performance marketing."
>
  <Nav current="clients" />

  <main id="top">
    <section class="page-hero">
      <div class="hero-glow"></div>
      <div class="page-label">clients</div>
      <h1 class="page-title">trusted by.</h1>
      <p class="page-tagline">10+ years. dozens of brands.</p>
    </section>

    <section class="section">
      {clients.length === 0 ? (
        <div class="empty">
          <p class="muted">client list landing soon — populating shortly.</p>
        </div>
      ) : (
        <div class="sectors">
          {sectors.map((sector) => (
            <div class="sector-group">
              <div class="sector-label">{sector}</div>
              <div class="client-grid">
                {grouped[sector].map((c) => (
                  <article class="client-card">
                    {c.url ? (
                      <a
                        href={c.url}
                        class="client-name"
                        target="_blank"
                        rel="noopener noreferrer"
                      >{c.name} ↗</a>
                    ) : (
                      <span class="client-name">{c.name}</span>
                    )}
                    {c.note && <p class="client-note">{c.note}</p>}
                  </article>
                ))}
              </div>
            </div>
          ))}
        </div>
      )}

      <div class="cta-row">
        <a
          href="https://calendly.com/michaeltawiah/autoads"
          target="_blank"
          rel="noopener noreferrer"
          class="cta-btn cta-btn-solid"
        >book a free 30-min chat</a>
        <a href="/" class="cta-btn cta-btn-outline">← back to home</a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .page-hero {
    position: relative;
    padding: 9rem 2rem 4rem;
    text-align: center;
    overflow: hidden;
  }
  .hero-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 60% 60% at 50% 50%,
      rgba(0, 255, 157, 0.08),
      transparent 70%
    );
    pointer-events: none;
  }
  .page-label {
    position: relative;
    color: var(--accent);
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }
  .page-title {
    position: relative;
    font-family: var(--font-mono);
    font-size: clamp(2.25rem, 7vw, 4rem);
    font-weight: 500;
    margin: 0;
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .page-tagline {
    position: relative;
    color: var(--accent);
    margin: 1.25rem 0 0;
    font-size: clamp(0.9rem, 2vw, 1.1rem);
  }

  .empty {
    border: 1px dashed var(--border);
    background: var(--card);
    padding: 4rem 2rem;
    text-align: center;
  }

  .sectors {
    display: grid;
    gap: 3rem;
  }
  .sector-group {
    border-top: 1px dashed var(--border);
    padding-top: 1.5rem;
  }
  .sector-group:first-child {
    border-top: none;
    padding-top: 0;
  }
  .sector-label {
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.3em;
    font-size: 0.7rem;
    margin-bottom: 1.5rem;
  }
  .client-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem;
  }
  .client-card {
    border: 1px solid var(--border);
    background: var(--card);
    padding: 1.25rem 1.25rem;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .client-card:hover {
    border-color: var(--accent-dim);
    transform: translateY(-2px);
  }
  .client-name {
    color: var(--fg);
    font-size: 0.95rem;
    font-weight: 500;
    display: inline-block;
  }
  a.client-name {
    transition: color 0.2s ease;
  }
  a.client-name:hover {
    color: var(--accent);
  }
  .client-note {
    color: var(--muted);
    font-size: 0.8rem;
    margin: 0.4rem 0 0;
  }

  .cta-row {
    margin-top: 4rem;
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .cta-btn {
    display: inline-block;
    padding: 0.85rem 1.25rem;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .cta-btn-outline {
    border: 1px solid var(--fg);
    color: var(--fg);
  }
  .cta-btn-outline:hover {
    background: var(--fg);
    color: #000;
  }
  .cta-btn-solid {
    background: var(--accent);
    color: #000;
    border: 1px solid var(--accent);
    font-weight: 500;
  }
  .cta-btn-solid:hover {
    background: transparent;
    color: var(--accent);
  }
</style>
